@using Microsoft.AspNetCore.Mvc.TagHelpers
@model AnalyticsModuleDiplomMVC.Controllers.CalendarViewModel

@{
    ViewData["Title"] = "Календарь посещаемости";
}

<div class="container-fluid">
    <!-- Выбор сотрудника -->
    <div class="row">
        <div class="col-md-12">
            <h2>Календарь посещаемости: @Model.Employee.FullName</h2>
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col-md-6">
                            <form asp-action="Index" method="get">
                                <div class="input-group">
                                    <select class="form-select" name="employeeId" id="employeeSelect" onchange="this.form.submit()">
                                        @foreach (var emp in Model.Employees)
                                        {
                                            <option value="@emp.Id">@emp.FullName</option>
                                        }
                                    </select>
                                </div>
                            </form>
                        </div>
                        <div class="col-md-6">
                            <div class="input-group">
                                <input type="date" class="form-control" id="dateFilter">
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Таблица посещаемости -->
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Дата</th>
                                    <th>Время прихода</th>
                                    <th>Время ухода</th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var record in Model.Records)
                                {
                                    <tr class="record-row" data-date="@record.Date.ToString("yyyy-MM-dd")">
                                        <td>@record.Date.ToShortDateString()</td>
                                        <td>
                                            @if (record.ArrivalTime.HasValue)
                                            {
                                                @record.ArrivalTime.Value.ToShortTimeString()
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Пропуск</span>
                                            }
                                        </td>
                                        <td>
                                            @if (record.DepartureTime.HasValue)
                                            {
                                                @record.DepartureTime.Value.ToShortTimeString()
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Пропуск</span>
                                            }
                                        </td>
                                        <td>
                                            @if (record.Status == AttendanceStatus.Late)
                                            {
                                                <span class="badge bg-warning">Опоздание</span>
                                            }
                                            else if (record.Status == AttendanceStatus.Overwork)
                                            {
                                                <span class="badge bg-success">Переработка</span>
                                            }
                                            else if (record.Status == AttendanceStatus.Absent)
                                            {
                                                <span class="badge bg-danger">Пропуск</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary">Норма</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Индивидуальный дашборд -->
    <div class="row mt-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Индивидуальный дашборд за месяц</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="card text-white bg-primary mb-3">
                                <div class="card-body">
                                    <h5 class="card-title">Отработано часов</h5>
                                    <p class="card-text">@Model.TotalHoursWorked.ToString("F1")</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-white bg-warning mb-3">
                                <div class="card-body">
                                    <h5 class="card-title">Опозданий</h5>
                                    <p class="card-text">@Model.TotalLateArrivals</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-white bg-success mb-3">
                                <div class="card-body">
                                    <h5 class="card-title">Переработок</h5>
                                    <p class="card-text">@Model.TotalOverworks</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-white bg-danger mb-3">
                                <div class="card-body">
                                    <h5 class="card-title">Пропусков</h5>
                                    <p class="card-text">@Model.TotalAbsences</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- График посещаемости -->
    <div class="row mt-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>График отработанных часов: @Model.Employee.FullName</h5>
                </div>
                <div class="card-body">
                    <canvas id="attendanceChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Установка выбранного сотрудника в select
            var employeeSelect = document.getElementById('employeeSelect');
            var selectedEmployeeId = @Model.Employee.Id;
            for (var i = 0; i < employeeSelect.options.length; i++) {
                if (employeeSelect.options[i].value == selectedEmployeeId) {
                    employeeSelect.selectedIndex = i;
                    break;
                }
            }

            // Построение графика посещаемости
            var dates = @Html.Raw(Json.Serialize(Model.Dates));
            var hoursWorked = @Html.Raw(Json.Serialize(Model.HoursWorked));

            var ctx = document.getElementById('attendanceChart').getContext('2d');
            var attendanceChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: dates,
                    datasets: [{
                        label: 'Отработанные часы',
                        data: hoursWorked,
                        borderColor: 'rgb(75, 192, 192)',
                        tension: 0.1,
                        fill: false
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Часы'
                            }
                        },
                        x: {
                            title: {
                                display: true,
                                text: 'Дата'
                            }
                        }
                    }
                }
            });
        });
    </script>
}
