@using Microsoft.AspNetCore.Mvc.TagHelpers
@model AnalyticsModuleDiplomMVC.Controllers.AnalyticsViewModel

@{
    ViewData["Title"] = "Аналитика";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>Дашборд с общей информацией</h2>
            <div class="card">
                <div class="card-header">
                    <h4>Аналитика</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="input-group">
                                <select class="form-select" id="departmentFilter">
                                    <option value="">Все отделы</option>
                                    @foreach (var dept in Model.Employees.Select(e => e.Department).Distinct())
                                    {
                                        <option value="@dept">@dept</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered" id="attendanceTable">
                            <thead>
                                <tr>
                                    <th>Подразделение</th>
                                    <th>ФИО</th>
                                    <th>Должность</th>
                                    <th>Статус</th>
                                    <th>Отработано часов</th>
                                    <th>Переработка</th>
                                    <th>Опоздания</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in Model.Employees)
                                {
                                    var marks = Model.AttendanceMarks.Where(m => m.EmployeeId == employee.Id).ToList();
                                    var totalHours = marks.Sum(m => (m.DepartureTime - m.ArrivalTime).TotalHours);
                                    var overworkHours = marks.Where(m => m.Status == "Переработка").Sum(m => (m.DepartureTime - m.ArrivalTime).TotalHours - 8);
                                    var lateArrivals = marks.Count(m => m.Status == "Опоздание");

                                    <tr class="employee-row" data-department="@employee.Department">
                                        <td>@employee.Department</td>
                                        <td>@employee.FullName</td>
                                        <td>@employee.Position</td>
                                        <td>
                                            @if (marks.Any(m => m.Status == "Опоздание"))
                                            {
                                                <span class="badge bg-warning">Опоздание</span>
                                            }
                                            @if (marks.Any(m => m.Status == "Переработка"))
                                            {
                                                <span class="badge bg-danger">Переработка</span>
                                            }
                                        </td>
                                        <td>@totalHours.ToString("F1")</td>
                                        <td>@overworkHours.ToString("F1")</td>
                                        <td>@lateArrivals</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const departmentFilter = document.getElementById('departmentFilter');
            const employeeRows = document.querySelectorAll('.employee-row');

            departmentFilter.addEventListener('change', function() {
                const selectedDepartment = this.value;
                employeeRows.forEach(row => {
                    if (selectedDepartment === "" || row.getAttribute('data-department') === selectedDepartment) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        });
    </script>
}
